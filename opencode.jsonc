{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "lsp": true,
  "provider": {
    "Free Models Router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Free Models Router",
      "options": {
        "baseURL": "http://127.0.0.1:9999/v1",
        "apiKey": "fake-key-proxy-handles-auth",
        "maxConcurrency": 1
      },
      "models": {
      /**/"z-ai/glm-5.2": {
          "name": "GLM-5.2 (Nvidia)",
          "limit": {"context": 200000, "output": 32768},
          "options": {
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 32768,
            "chat_template_kwargs": {"enable_thinking": true, "clear_thinking": true},
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        },
        "deepseek-ai/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (Nvidia)",
          "limit": {"context": 200000, "output": 16384},
          "options": {
            "stream": true,
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 16384,
            "reasoning_effort": "max",
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        },
        "minimaxai/minimax-m3": {
          "name": "MiniMax M3 (Nvidia)",
          "limit": {"context": 200000, "output": 16384},
          "options": {
            "stream": true,
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 16384,
            "chat_template_kwargs": {"thinking_mode": "adaptive"},
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        },
        "gpt-5.5-free": {
          "name": "GPT-5.5 Free (AIHubMix)",
          "limit": {"context": 200000, "output": 16384},
          "options": {
            "stream": true,
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 16384,
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        },
        "coding-glm-5.2-free": {
          "name": "Coding GLM-5.2 Free (AIHubMix)",
          "limit": {"context": 200000, "output": 32768},
          "options": {
            "stream": true,
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 32768,
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        },
        "xiaomi-mimo-v2.5-pro-free": {
          "name": "Xiaomi MiMo V2.5 Pro Free (AIHubMix)",
          "limit": {"context": 200000, "output": 16384},
          "options": {
            "stream": true,
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 16384,
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        },
        "coding-minimax-m3-free": {
          "name": "Coding MiniMax M3 Free (AIHubMix)",
          "limit": {"context": 200000, "output": 16384},
          "options": {
            "stream": true,
            "temperature": 0.7,
            "top_p": 0.9,
            "max_tokens": 16384,
            "stream_options": {"include_usage": true, "continuous_usage_stats": true}
          }
        }
      }
    }
  },
  "model": "Free Models Router/z-ai/glm-5.2"
}
