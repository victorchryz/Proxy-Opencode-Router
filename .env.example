# =====================================================================
# 🔑 CHAVES DA API NVIDIA
# =====================================================================
# Pelo menos 1 obrigatória. Mais chaves = mais capacidade de rotação.
# Cada chave é uma conta NVIDIA NIM separada, com seus próprios rate limits.
# =====================================================================

NVIDIA_KEY_1=nvapi-sua-chave-aqui
NVIDIA_KEY_2=nvapi-sua-chave-aqui

AIHUBMIX_KEY_1=sk-sua-chave-aqui
AIHUBMIX_KEY_2=sk-sua-chave-aqui

# =====================================================================
# 🌐 REDE DO PROXY (opcional)
# =====================================================================
# Porta e host onde o proxy escuta.
# No opencode.jsonc do seu projeto, aponte baseURL para http://HOST:PORT/v1
# =====================================================================

PROXY_HOST=127.0.0.1
PROXY_PORT=9999

# =====================================================================
# ⏱️ TIMEOUTS (opcional, em milissegundos)
# =====================================================================
# PROXY_CONN_TIMEOUT_MS   = tempo máximo de espera até o primeiro byte
#                          do modelo responder (conexão inicial).
# PROXY_STREAM_TIMEOUT_MS = tempo máximo de silêncio entre chunks do stream.
#                          Se o modelo ficar X ms sem mandar NADA, aborta.
#                          O timer reinicia a cada chunk recebido.
# =====================================================================

PROXY_CONN_TIMEOUT_MS=30000
PROXY_STREAM_TIMEOUT_MS=90000

# =====================================================================
# 🚦 RATE LIMIT E CONCORRÊNCIA (opcional)
# =====================================================================
# PROXY_TARGET_RPM  = limite GLOBAL de requests por minuto (fila).
# PROXY_MAX_CONCURRENT = quantas requisições simultâneas no máximo.
#                        Aumentar faz o modelo usar mais capacidade por turno,
#                        mas pode estourar rate limit da NVIDIA mais rápido.
# =====================================================================

PROXY_TARGET_RPM=40
PROXY_MAX_CONCURRENT=4

# =====================================================================
# 🈶 CJK STRIPPING (opcional)
# =====================================================================
# Remove caracteres CJK (chinês, japonês, coreano) do content e reasoning_content
# no stream SSE. ATENÇÃO: os modelos configurados são chineses e respondem
# frequentemente em chinês. Deixe 0 (desativado) para preservar o conteúdo.
# Use 1 apenas se quiser remover CJK por algum motivo específico.
# =====================================================================

PROXY_STRIP_CJK=1

# =====================================================================
# 🧪 MODO DE TESTE (não use em produção)
# =====================================================================
# PROXY_TEST_MODE=1 ativa chaves mock que NÃO funcionam com a API real.
# Serve apenas para verificar se o proxy inicia corretamente sem chaves reais.
# Em produção, deixe DESATIVADO ou remova a linha.
# =====================================================================

# PROXY_TEST_MODE=0

# =====================================================================
# 🌍 URL BASE DA NVIDIA (opcional, para testes)
# =====================================================================
# Permite apontar para um servidor mock ou espelho da API NVIDIA.
# Útil para testar o proxy.
# Deixe comentado para não usar a URL oficial.
# =====================================================================

# NVIDIA_BASE_URL=https://integrate.api.nvidia.com

# =====================================================================
# 🌐 URL BASE DA AIHUBMIX (opcional)
# =====================================================================

# AIHUBMIX_BASE_URL=https://aihubmix.com
